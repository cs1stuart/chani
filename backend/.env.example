PORT=3002
# Chatvia MongoDB: use YOUR cluster hostname (not another project's).
# Option A – full URI with credentials:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@YOUR-CLUSTER.mongodb.net/chatvia
# Option B – base URI + separate user/pass (password can contain @ # : etc):
MONGODB_URI=mongodb+srv://YOUR-CLUSTER.mongodb.net/chatvia
MONGODB_USER=your_atlas_user
MONGODB_PASSWORD=your_atlas_password

JWT_SECRET=workchat-super-secret-key-2026-change-me 